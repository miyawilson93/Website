# Server
PORT=4242
PUBLIC_BASE_URL=http://localhost:4242
FRONTEND_BASE_URL=http://localhost:4242
# Comma-separated list of allowed origins that can call checkout API.
# Example: ALLOWED_ORIGINS=https://movewiseal.com,https://www.movewiseal.com
ALLOWED_ORIGINS=http://localhost:4242
STRIPE_ALLOW_LIVE_MODE=false

# Stripe keys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Core plan mappings used on Buying/Selling page
# Prefer Stripe Price IDs (price_...). Product IDs (prod_...) are also accepted.
STRIPE_PRICE_3_MONTH=price_replace_me
STRIPE_PRICE_6_MONTH=price_replace_me

# Optional: map additional catalog items from your site
# Prefer Stripe Price IDs (price_...). Product IDs (prod_...) are also accepted.
STRIPE_PRICE_COACHING_MONTHLY=price_replace_me
STRIPE_PRICE_COACHING_6_MONTH=price_replace_me
STRIPE_PRICE_COACHING_12_MONTH=price_replace_me
STRIPE_PRICE_GROUP_COACHING_6_MONTH=price_replace_me
STRIPE_PRICE_VIP_INTENSIVE_6_MONTH=price_replace_me
STRIPE_PRICE_VIP_INTENSIVE_12_MONTH=price_replace_me
STRIPE_PRICE_NEW_AGENT_STARTER_KIT=price_replace_me
STRIPE_PRICE_SOCIAL_MEDIA_CALENDAR=price_replace_me
STRIPE_PRICE_BUYER_CONSULTATION_GUIDE=price_replace_me
STRIPE_PRICE_SELLER_CONSULTATION_GUIDE=price_replace_me
STRIPE_PRICE_CUSTOM_BUSINESS_WEBSITE=price_replace_me
STRIPE_PRICE_AGENT_MERCH=price_replace_me

